# Spotify dev app — https://developer.spotify.com/dashboard
# Premium account required (Feb 2026 dev-mode rule).
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback

# Last.fm — https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USERNAME=your_lastfm_username_here

# Ticketmaster Discovery API — https://developer.ticketmaster.com
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# Bandsintown public API — any unique app id string is accepted
BANDSINTOWN_APP_ID=gig-finder-skill
